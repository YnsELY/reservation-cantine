# Configuration Supabase (déjà configuré)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Configuration PayZone (à configurer dans Supabase Secrets)
# Ces variables ne sont PAS utilisées côté client, mais côté Edge Functions
# Configurez-les avec: supabase secrets set VARIABLE=value

# PAYZONE_MERCHANT_ACCOUNT=childrens_kitchen_Test
# PAYZONE_SECRET_KEY=votre_secret_key
# PAYZONE_URL=https://payment-sandbox.payzone.ma/pwthree/launch
# PAYZONE_NOTIFICATION_KEY=votre_notification_key
# APP_BASE_URL=https://childrens-kitchen.netlify.app
