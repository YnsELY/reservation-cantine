{
  "expo": {
    "name": "Child's Kitchen",
    "slug": "bolt-expo-nativewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.childrenskitchen.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.childrenskitchen.app",
      "googleServicesFile": "./google-services.json",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo.png",
          "imageWidth": 220,
          "dark": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/logo.png",
            "imageWidth": 220
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4F46E5",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://wreusophfpedauznrjfl.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndyZXVzb3BoZnBlZGF1em5yamZsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjIwODY5MjAsImV4cCI6MjA3NzY2MjkyMH0.l2IXPfhOgWKO_KyLdQ7yjS_0RxCT6gkCXfeRUOerTxs",
      "router": {},
      "eas": {
        "projectId": "202f88c6-27b8-469d-bb1a-e68e46c204ea"
      }
    },
    "owner": "yns_ely"
  }
}
